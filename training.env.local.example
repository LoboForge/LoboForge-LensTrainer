# === LOCAL WORKSTATION ONLY ===
#   cp training.env.local.example training.env
#   bash scripts/train_local.sh
#
# RunPod is separate: training.env.runpod.example + scripts/train_runpod.sh

DATASET_PATH=/home/wrath/Documents/LoboForge/DualCharacterLoras
LORA_NAME=lens-lora-dual-character
OUTPUT_DIR=/media/wrath/AI/LensTrainer-LoboForge/output/lens-lora-dual-character

TRAIN_PRESET=configs/train_lora_dual_character_24gb.yaml
STEPS=8000
SAVE_EVERY=250
SAMPLE_EVERY=400

TRIGGER_WORD=
LORA_RANK=
LORA_ALPHA=

MODEL_REPO=/media/wrath/AI/LensTrainer-LoboForge/models/Lens-Base
# 16GB GPU (e.g. ~15.5GB VRAM): true. 20GB+: can try false if kernels installed.
DISABLE_MXFP4=true
RESOLUTION=0
BASELINE_CONTROL=false
