# === RUNPOD / CLOUD GPU ONLY ===
#   cp training.env.runpod.example training.env
#   bash scripts/train_runpod.sh
#
# Local workstation: training.env.local.example + scripts/train_local.sh

DATASET_PATH=/workspace/DualCharacterLora
LORA_NAME=lens-lora-dual-character
OUTPUT_DIR=/workspace/output/lens-lora-dual-character

TRAIN_PRESET=configs/train_runpod_gpu.yaml
STEPS=8000
SAVE_EVERY=250
SAMPLE_EVERY=400

TRIGGER_WORD=
MODEL_REPO=/workspace/LoboForge-LensTrainer/models/Lens-Base
DISABLE_MXFP4=false
RESOLUTION=0
BASELINE_CONTROL=false
