# Copy to training.env and edit (bootstrap creates training.env from this if missing).
#   cp training.env.example training.env

# --- Required ---
DATASET_PATH=/workspace/DualCharacterLora

# --- Run identity ---
LORA_NAME=lens-lora-dual-character
OUTPUT_DIR=/workspace/output/lens-lora-dual-character

# --- Training ---
TRAIN_PRESET=configs/train_lora_dual_character_24gb.yaml
STEPS=8000
SAVE_EVERY=250
SAMPLE_EVERY=400

# --- LoRA / prompts ---
TRIGGER_WORD=
LORA_RANK=
LORA_ALPHA=

# --- Model (bootstrap fills this path after download) ---
MODEL_REPO=/workspace/LoboForge-LensTrainer/models/Lens-Base
# RTX 50xx: DISABLE_MXFP4=false for faster text cache
DISABLE_MXFP4=true

# --- Dataset ---
# 0 = auto native resolution; 1024 = force square
RESOLUTION=0

# --- Resume / previews ---
# RESUME_FROM=latest
BASELINE_CONTROL=true
# BASELINE_CONTROL=false
