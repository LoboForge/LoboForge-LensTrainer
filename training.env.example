# Local machine — copy to training.env:
#   cp training.env.example training.env
#
# RunPod copy instead:
#   cp training.env.runpod.example training.env

# --- Required ---
DATASET_PATH=/home/wrath/Documents/LoboForge/DualCharacterLoras

# --- Run identity ---
LORA_NAME=lens-lora-dual-character
OUTPUT_DIR=/media/wrath/AI/LensTrainer-LoboForge/output/lens-lora-dual-character

# --- Training ---
TRAIN_PRESET=configs/train_lora_dual_character_24gb.yaml
STEPS=8000
SAVE_EVERY=250
SAMPLE_EVERY=400

# --- LoRA / prompts ---
TRIGGER_WORD=
LORA_RANK=
LORA_ALPHA=

# --- Model (local assembled Lens-Base folder) ---
MODEL_REPO=/media/wrath/AI/LensTrainer-LoboForge/models/Lens-Base
DISABLE_MXFP4=false

# --- Dataset ---
RESOLUTION=0

# --- Resume / previews ---
BASELINE_CONTROL=false
# RESUME_FROM=latest
